{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "strict": true,
        "noImplicitAny": false,
        "moduleResolution": "node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "types": [
            "miniprogram-api-typings"
        ],
        "baseUrl": "./",
        "paths": {
            "@/*": [
                "*"
            ]
        }
    }
}